{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "PureLang",
  "scopeName": "source.pure",
  "fileTypes": ["pure"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#data-decl" },
    { "include": "#function-decl" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.pure",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.pure",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.pure",
          "match": "\\\\(n|t|r|\\\\|\"|\\$|0)"
        },
        {
          "name": "variable.other.interpolation.pure",
          "match": "\\$[A-Za-z_][A-Za-z_0-9]*"
        },
        {
          "name": "meta.embedded.expression.pure",
          "begin": "\\$\\{",
          "end": "\\}",
          "patterns": [
            { "include": "$self" }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.pure",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.pure",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.pure",
          "match": "\\b(use|pub|var|if|else|for|in|when|return|object|extend|shape|async|await|try|throw)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.pure",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.builtin.pure",
          "match": "\\b(Int|Float|Bool|String|Null|Void|Any|List|Function)\\b"
        },
        {
          "name": "entity.name.type.pure",
          "match": "\\b[A-Z][A-Za-z_0-9]*\\b"
        }
      ]
    },
    "data-decl": {
      "patterns": [
        {
          "match": "^\\s*([A-Z][A-Za-z_0-9]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.type.pure" }
          }
        }
      ]
    },
    "function-decl": {
      "patterns": [
        {
          "match": "^\\s*([a-z_][A-Za-z_0-9]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.function.pure" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pure",
          "match": "(=>|->|==|!=|<=|>=|&&|\\|\\||\\?\\.|\\?:|\\?|\\+|-|\\*|/|%|=|<|>|!|\\.|,|:)"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.pure",
          "match": "\\b[a-z_][A-Za-z_0-9]*\\b"
        }
      ]
    }
  }
}
